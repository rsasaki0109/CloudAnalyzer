# Canonical schema reference for the kitti-mini suite. The actual
# `suite.yaml` is generated by `scripts/prepare_kitti_mini.py` from a
# local KITTI Odometry download — see README.md for the workflow.
#
# This file is checked in for documentation only; `ca benchmark *`
# does not read `.example` files.

version: 1
name: kitti-mini
description: KITTI Odometry sequence_00 (reference map downsampled to 0.50 m, GT trajectory subsampled to 2000 poses).
license: CC-BY-NC-SA 3.0 (KITTI Odometry Benchmark, Geiger et al., CVPR 2012)

sequences:
  sequence_00:
    description: KITTI Odometry sequence_00 GT bundle.
    reference_map: data/sequence_00/map.pcd
    reference_trajectory: data/sequence_00/trajectory.tum

gate:
  # Outdoor-scale starter gate. KITTI sequences span 500-2000 m, so
  # the absolute ATE / drift tolerances are larger than indoor datasets.
  # Recalibrate from a known-good SLAM run.
  min_auc: 0.85
  max_chamfer: 0.50
  max_ate: 5.00
  max_rpe: 1.00
  max_drift: 5.00
  min_coverage: 0.80
