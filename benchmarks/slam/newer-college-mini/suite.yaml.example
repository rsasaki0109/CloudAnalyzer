# Canonical schema reference for the newer-college-mini suite. The
# actual `suite.yaml` is generated by
# `scripts/prepare_newer_college_mini.py` from a local Newer College
# Dataset download — see README.md for the workflow.
#
# This file is checked in for documentation only; `ca benchmark *`
# does not read `.example` files.

version: 1
name: newer-college-mini
description: Newer College Dataset short_experiment sequence (GT map downsampled to 0.10 m, GT trajectory subsampled to 2000 poses).
license: CC-BY-NC-SA 4.0 (Newer College Dataset, Ramezani et al., IROS 2020)

sequences:
  short_experiment:
    description: Newer College Dataset short_experiment GT bundle.
    reference_map: data/short_experiment/map.pcd
    reference_trajectory: data/short_experiment/trajectory.tum

gate:
  # Conservative starter gate. Recalibrate from a known-good SLAM run.
  min_auc: 0.90
  max_chamfer: 0.30
  max_ate: 0.50
  max_rpe: 0.20
  max_drift: 1.50
  min_coverage: 0.85
